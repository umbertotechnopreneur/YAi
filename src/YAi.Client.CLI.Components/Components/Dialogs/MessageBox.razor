@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using RazorConsole.Components
@using Spectre.Console

<Rows>
    <Panel Title="@_title">
        <Rows>
            <Markup Content="@Message" Foreground="@_foreground" />
            <Newline />
            <TextButton Content="[Enter] OK"
                        OnClick="DismissClicked"
                        BackgroundColor="@Color.Grey"
                        FocusedColor="@Color.Silver" />
        </Rows>
    </Panel>
</Rows>

@code {
    /// <summary>Severity levels for a MessageBox.</summary>
    public enum MessageSeverity { Info, Warning, Error }

    /// <summary>Display severity. Drives color and title prefix.</summary>
    [Parameter] public MessageSeverity Severity { get; set; } = MessageSeverity.Info;

    /// <summary>Optional title override. Defaults to severity name.</summary>
    [Parameter] public string? TitleOverride { get; set; }

    /// <summary>Message body.</summary>
    [Parameter] public string Message { get; set; } = string.Empty;

    /// <summary>Raised when the user dismisses the dialog.</summary>
    [Parameter] public EventCallback OnDismiss { get; set; }

    private string _title = string.Empty;
    private Color _foreground = Color.White;

    protected override void OnParametersSet ()
    {
        (_title, _foreground) = Severity switch
        {
            MessageSeverity.Warning => (TitleOverride ?? "⚠ Warning", Color.Yellow),
            MessageSeverity.Error   => (TitleOverride ?? "✗ Error",   Color.Red),
            _                       => (TitleOverride ?? "ℹ Info",    Color.Cyan1)
        };
    }

    private async Task DismissClicked () => await OnDismiss.InvokeAsync ();
}
