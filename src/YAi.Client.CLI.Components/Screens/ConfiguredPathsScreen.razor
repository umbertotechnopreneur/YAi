@using System.Linq
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console
@using YAi.Persona.Services

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<bool> Result
@inject AppPaths Paths

<Rows>
    <Panel Title="Configured paths">
        <Rows>
            <Markup Content="These locations are resolved from AppPaths and should stay in sync with any new configuration, memory, skill, or storage paths." Foreground="@Color.Silver" />
            <Newline />

            @if (_assetEntries.Count > 0)
            {
                <Markup Content="Asset and template paths" Foreground="@Color.Cyan1" />

                @foreach (PathEntryViewModel entry in _assetEntries)
                {
                    <Columns>
                        <Markup Content="@entry.Scope" />
                        <Markup Content="@entry.Category" />
                        <Markup Content="@entry.Label" />
                        <Markup Content="@entry.Path" />
                    </Columns>
                }

                <Newline />
            }

            @if (_customEntries.Count > 0)
            {
                <Markup Content="Custom runtime paths" Foreground="@Color.Yellow" />

                @foreach (PathEntryViewModel entry in _customEntries)
                {
                    <Columns>
                        <Markup Content="@entry.Scope" />
                        <Markup Content="@entry.Category" />
                        <Markup Content="@entry.Label" />
                        <Markup Content="@entry.Path" />
                    </Columns>
                }
            }
        </Rows>
    </Panel>
</Rows>

@code {
    private sealed record PathEntryViewModel (string Scope, string Category, string Label, string Path);

    private IReadOnlyList<PathEntryViewModel> _assetEntries = [];
    private IReadOnlyList<PathEntryViewModel> _customEntries = [];

    protected override void OnInitialized ()
    {
        IReadOnlyList<(string Category, string Label, string Path, bool IsCustom)> entries = Paths.GetConfiguredPathEntries ();

        _assetEntries = entries
            .Where (entry => !entry.IsCustom)
            .Select (entry => new PathEntryViewModel (
                "[cyan]asset[/]",
                Escape (entry.Category),
                Escape (entry.Label),
                Escape (entry.Path)))
            .ToArray ();

        _customEntries = entries
            .Where (entry => entry.IsCustom)
            .Select (entry => new PathEntryViewModel (
                "[yellow]custom[/]",
                Escape (entry.Category),
                Escape (entry.Label),
                Escape (entry.Path)))
            .ToArray ();
    }

    protected override Task OnAfterRenderAsync (bool firstRender)
    {
        if (firstRender)
        {
            Result.SetResult (true);
            AppLifetime.StopApplication ();
        }

        return Task.CompletedTask;
    }

    private static string Escape (string value)
    {
        return Spectre.Console.Markup.Escape (value);
    }
}