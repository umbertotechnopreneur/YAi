@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<bool> Result

<Rows>
    <Newline />

    <Panel>
        <Rows>
            <RawMarkup Content="@BannerArt" Foreground="@Color.Cyan1" />
            <Newline />
            <RawMarkup Content="Copyright © 2019-2026 UmbertoGiacobbiDotBiz. All rights reserved."
                       Foreground="@Color.Grey70" />
            <RawMarkup Content="Website: https://umbertogiacobbi.biz" Foreground="@Color.DeepSkyBlue1" />
            <RawMarkup Content="Email: hello@umbertogiacobbi.biz" Foreground="@Color.SpringGreen2" />
        </Rows>
    </Panel>

    <Newline />
</Rows>

@code {
    private const string BannerArt = """
╔════════════════╗
║      YAi!      ║
╚════════════════╝
""";

    protected override Task OnAfterRenderAsync (bool firstRender)
    {
        if (!firstRender)
        {
            return Task.CompletedTask;
        }

        Result.SetResult (true);
        AppLifetime.StopApplication ();

        return Task.CompletedTask;
    }
}