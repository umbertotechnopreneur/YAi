@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console
@using YAi.Persona.Models
@using YAi.Persona.Services

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<OpenRouterModel> Result
@inject OpenRouterCatalogService CatalogService
@inject AppConfig AppConfig

<Rows>
    <Panel Title="@Title">
        <Rows>
            @if (_isLoading)
            {
                <RawMarkup Content="@LoadingMessageMarkup" />
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace (_subtitleMarkup))
                {
                    <RawMarkup Content="@_subtitleMarkup" />
                }

                <RawMarkup Content="@_searchStateMarkup" />
                <RawMarkup Content="@_matchCountMarkup" />
                <RawMarkup Content="@PromptHintMarkup" />
                <Newline />

                if (_pageCards.Count == 0)
                {
                    <RawMarkup Content="[red]No matches found.[/]" />
                }
                else
                {
                    @if (!string.IsNullOrWhiteSpace (_pageSummaryMarkup))
                    {
                        <RawMarkup Content="@_pageSummaryMarkup" />
                    }

                    @for (int row = 0; row < _pageCards.Count; row += 2)
                    {
                        OpenRouterModelCardViewModel left = _pageCards[row];
                        OpenRouterModelCardViewModel? right = row + 1 < _pageCards.Count
                            ? _pageCards[row + 1]
                            : null;

                        <Columns>
                            <Panel Title="@left.Title">
                                <Rows>
                                    <RawMarkup Content="@left.SelectionBadge" />
                                    <RawMarkup Content="@left.ProviderMarkup" />
                                    <RawMarkup Content="@left.KeyMarkup" />
                                    <RawMarkup Content="@left.NameMarkup" />
                                    <RawMarkup Content="@left.CostMarkup" />
                                    <RawMarkup Content="@left.DescriptionMarkup" />
                                </Rows>
                            </Panel>

                            @if (right is not null)
                            {
                                <Panel Title="@right.Title">
                                    <Rows>
                                        <RawMarkup Content="@right.SelectionBadge" />
                                        <RawMarkup Content="@right.ProviderMarkup" />
                                        <RawMarkup Content="@right.KeyMarkup" />
                                        <RawMarkup Content="@right.NameMarkup" />
                                        <RawMarkup Content="@right.CostMarkup" />
                                        <RawMarkup Content="@right.DescriptionMarkup" />
                                    </Rows>
                                </Panel>
                            }
                            else
                            {
                                <RawMarkup Content="" />
                            }
                        </Columns>
                    }
                }
            }
        </Rows>
    </Panel>
</Rows>

@code {
    private readonly List<OpenRouterModel> _allModels = [];
    private readonly List<OpenRouterModel> _visibleModels = [];
    private readonly List<OpenRouterModelCardViewModel> _pageCards = [];

    private OpenRouterModelCatalog? _catalog;
    private string _searchQuery = string.Empty;
    private bool _searchMode;
    private int _selectedIndex;
    private bool _isLoading = true;
    private bool _selectionLoopStarted;
    private string _subtitleMarkup = string.Empty;
    private string _searchStateMarkup = string.Empty;
    private string _matchCountMarkup = string.Empty;
    private string _pageSummaryMarkup = string.Empty;

    protected override async Task OnInitializedAsync ()
    {
        _isLoading = true;
        AnsiConsole.MarkupLine ($"[cyan]{Spectre.Console.Markup.Escape (LoadingMessage)}[/]");

        _catalog = await CatalogService.GetCatalogAsync ().ConfigureAwait (false);

        _allModels.Clear ();
        _allModels.AddRange(OpenRouterModelSelectionHelper.BuildOrderedModels(_catalog));

        if (_allModels.Count == 0)
        {
            throw new InvalidOperationException (
                "No OpenRouter models were available. Check the network connection or the cached catalog file.");
        }

        _isLoading = false;
        RefreshViewState ();
    }

    protected override Task OnAfterRenderAsync (bool firstRender)
    {
        if (!_selectionLoopStarted && !_isLoading)
        {
            _selectionLoopStarted = true;
            _ = StartSelectionLoopAsync ();
        }

        return Task.CompletedTask;
    }

    private string Title => "OpenRouter model selector";

    private string LoadingMessage => "Loading OpenRouter model catalog...";

    private string LoadingMessageMarkup => $"[cyan]{Spectre.Console.Markup.Escape (LoadingMessage)}[/]";

    private string PromptHintMarkup => "[grey70]Use arrow keys to move, Enter to select, or Esc to cancel.[/]";

    private async Task StartSelectionLoopAsync ()
    {
        await Task.Yield ();

        if (Console.IsInputRedirected || Console.IsOutputRedirected)
        {
            throw new InvalidOperationException ("OpenRouter model selection requires an interactive console.");
        }

        while (true)
        {
            ConsoleKeyInfo key = Console.ReadKey (intercept: true);
            OpenRouterModel? currentSelection = OpenRouterModelSelectionHelper.GetCurrentSelection (_visibleModels, _selectedIndex);

            if (_searchMode)
            {
                if (await HandleSearchModeKeyAsync (key, currentSelection).ConfigureAwait (false))
                {
                    return;
                }

                continue;
            }

            if (await HandleBrowseModeKeyAsync (key, currentSelection).ConfigureAwait (false))
            {
                return;
            }
        }
    }

    private async Task<bool> HandleSearchModeKeyAsync (ConsoleKeyInfo key, OpenRouterModel? currentSelection)
    {
        if (key.Key == ConsoleKey.Escape)
        {
            string? currentSelectionId = currentSelection?.Id;

            _searchQuery = string.Empty;
            _searchMode = false;
            await RefreshAndRenderAsync (currentSelectionId).ConfigureAwait (false);
            return false;
        }

        if (key.Key == ConsoleKey.Backspace)
        {
            if (_searchQuery.Length > 0)
            {
                string? currentSelectionId = currentSelection?.Id;

                _searchQuery = _searchQuery[..^1];
                await RefreshAndRenderAsync (currentSelectionId).ConfigureAwait (false);
            }

            return false;
        }

        if (key.Key == ConsoleKey.Enter)
        {
            if (_visibleModels.Count == 0)
            {
                return false;
            }

            CompleteSelection (_visibleModels[_selectedIndex]);
            return true;
        }

        if (OpenRouterModelSelectionHelper.IsCursorKey (key.Key))
        {
            _selectedIndex = OpenRouterModelSelectionHelper.HandleCursorKey (_visibleModels, _selectedIndex, key.Key);
            await RefreshAndRenderAsync (_visibleModels[_selectedIndex].Id).ConfigureAwait (false);
            return false;
        }

        if (OpenRouterModelSelectionHelper.IsSearchCharacter (key))
        {
            string? currentSelectionId = currentSelection?.Id;

            _searchQuery += key.KeyChar;
            await RefreshAndRenderAsync (currentSelectionId).ConfigureAwait (false);
        }

        return false;
    }

    private async Task<bool> HandleBrowseModeKeyAsync (ConsoleKeyInfo key, OpenRouterModel? currentSelection)
    {
        if (key.Key == ConsoleKey.Escape)
        {
            Result.SetResult (null!);
            AppLifetime.StopApplication ();
            return true;
        }

        if (key.Key == ConsoleKey.Enter)
        {
            if (_visibleModels.Count == 0)
            {
                return false;
            }

            CompleteSelection (_visibleModels[_selectedIndex]);
            return true;
        }

        if (OpenRouterModelSelectionHelper.IsCursorKey (key.Key))
        {
            _selectedIndex = OpenRouterModelSelectionHelper.HandleCursorKey (_visibleModels, _selectedIndex, key.Key);
            await RefreshAndRenderAsync (_visibleModels[_selectedIndex].Id).ConfigureAwait (false);
            return false;
        }

        if (OpenRouterModelSelectionHelper.IsSearchCharacter (key))
        {
            _searchMode = true;
            _searchQuery = key.KeyChar.ToString ();
            await RefreshAndRenderAsync (currentSelection?.Id).ConfigureAwait (false);
        }

        return false;
    }

    private void RefreshViewState (string? selectedModelId = null)
    {
        OpenRouterModelSelectionViewState viewState = OpenRouterModelSelectionHelper.BuildViewState(
            _allModels,
            _catalog,
            AppConfig,
            _searchQuery,
            _searchMode,
            selectedModelId);

        _visibleModels.Clear ();
        _visibleModels.AddRange(viewState.VisibleModels);
        _selectedIndex = viewState.SelectedIndex;

        _pageCards.Clear ();
        _pageCards.AddRange(viewState.PageCards);

        _subtitleMarkup = viewState.SubtitleMarkup;
        _searchStateMarkup = viewState.SearchStateMarkup;
        _matchCountMarkup = viewState.MatchCountMarkup;
        _pageSummaryMarkup = viewState.PageSummaryMarkup;
    }

    private Task RefreshAndRenderAsync (string? selectedModelId = null)
    {
        RefreshViewState (selectedModelId);

        return InvokeAsync (StateHasChanged);
    }

    private void CompleteSelection(OpenRouterModel selectedModel)
    {
        Result.SetResult(selectedModel);
        AppLifetime.StopApplication();
    }
}