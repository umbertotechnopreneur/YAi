@using System.Linq
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console
@using YAi.Persona.Services

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<bool> Result
@inject AppPaths Paths

<Rows>
    <AppHeader />

    <Panel Title="Configured paths">
        <Rows>
            <RawMarkup
            Content="These locations are resolved from AppPaths and should stay in sync with any new configuration, memory, skill, or storage paths."
            Foreground="@Color.Silver" />
            <Newline />

            <Columns>
                <Panel Title="Assets">
                    <Rows>
                        <RawMarkup Content="@GetAssetSummaryMarkup()" />
                    </Rows>
                </Panel>
                <Panel Title="Custom">
                    <Rows>
                        <RawMarkup Content="@GetCustomSummaryMarkup()" />
                    </Rows>
                </Panel>
                <Panel Title="Total">
                    <Rows>
                        <RawMarkup Content="@GetTotalSummaryMarkup()" />
                    </Rows>
                </Panel>
            </Columns>

            <Newline />

            <Panel Title="Asset and template paths">
                <Rows>
                    @if (_assetEntries.Count > 0)
                    {
                        @foreach (PathEntryViewModel entry in _assetEntries)
                        {
                            <Columns>
                                <RawMarkup Content="@entry.Scope" />
                                <RawMarkup Content="@entry.Category" />
                                <RawMarkup Content="@entry.Label" />
                                <RawMarkup Content="@entry.Path" />
                            </Columns>
                        }
                    }
                    else
                    {
                        <RawMarkup Content="[grey70]No asset paths were resolved.[/]" />
                    }
                </Rows>
            </Panel>

            <Newline />

            <Panel Title="Custom runtime paths">
                <Rows>
                    @if (_customEntries.Count > 0)
                    {
                        @foreach (PathEntryViewModel entry in _customEntries)
                        {
                            <Columns>
                                <RawMarkup Content="@entry.Scope" />
                                <RawMarkup Content="@entry.Category" />
                                <RawMarkup Content="@entry.Label" />
                                <RawMarkup Content="@entry.Path" />
                            </Columns>
                        }
                    }
                    else
                    {
                        <RawMarkup Content="[grey70]No custom runtime paths were resolved.[/]" />
                    }
                </Rows>
            </Panel>
        </Rows>
    </Panel>
</Rows>

@code {
    private sealed record PathEntryViewModel (string Scope, string Category, string Label, string Path);

    private IReadOnlyList<PathEntryViewModel> _assetEntries = [];
    private IReadOnlyList<PathEntryViewModel> _customEntries = [];

    protected override void OnInitialized ()
    {
        IReadOnlyList<(string Category, string Label, string Path, bool IsCustom)> entries = Paths.GetConfiguredPathEntries ();

        _assetEntries = entries
            .Where (entry => !entry.IsCustom)
            .Select (entry => new PathEntryViewModel (
                "[cyan]asset[/]",
                Escape (entry.Category),
                Escape (entry.Label),
                Escape (entry.Path)))
            .ToArray ();

        _customEntries = entries
            .Where (entry => entry.IsCustom)
            .Select (entry => new PathEntryViewModel (
                "[yellow]custom[/]",
                Escape (entry.Category),
                Escape (entry.Label),
                Escape (entry.Path)))
            .ToArray ();
    }

    protected override Task OnAfterRenderAsync (bool firstRender)
    {
        if (firstRender)
        {
            Result.SetResult (true);
            AppLifetime.StopApplication ();
        }

        return Task.CompletedTask;
    }

    private static string Escape (string value)
    {
        return Spectre.Console.Markup.Escape (value);
    }

    private string GetAssetSummaryMarkup()
    {
        return $"[bold cyan1]{_assetEntries.Count}[/]\n[grey70]asset and template paths[/]";
    }

    private string GetCustomSummaryMarkup()
    {
        return $"[bold yellow]{_customEntries.Count}[/]\n[grey70]workspace, memory, data, config, and logs[/]";
    }

    private string GetTotalSummaryMarkup()
    {
        return $"[bold springgreen2]{_assetEntries.Count + _customEntries.Count}[/]\n[grey70]resolved entries[/]";
    }
}