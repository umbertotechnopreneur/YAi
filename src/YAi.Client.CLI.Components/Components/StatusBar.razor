@namespace YAi.Client.CLI.Components

@using Microsoft.AspNetCore.Components
@using RazorConsole.Components
@using YAi.Client.CLI.Components.Rendering

<Panel Expand="true">
    <RawMarkup Content="@StatusBarMarkupRenderer.BuildMarkup(State)" />
</Panel>

@code {
    /// <summary>
    /// Gets or sets the status bar state to render.
    /// </summary>
    [Parameter]
    [EditorRequired]
    public StatusBarState State { get; set; } = StatusBarState.Local("idle", "ready");
}