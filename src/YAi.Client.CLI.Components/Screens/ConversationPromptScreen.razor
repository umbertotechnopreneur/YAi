@namespace YAi.Client.CLI.Components

@using System
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console
@using YAi.Client.CLI.Components.Input
@using YAi.Client.CLI.Components.Rendering
@using YAi.Client.CLI.Components.Screens

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<ConversationPromptScreenResult> Result
@inject ConversationPromptScreenParameters ScreenParams

<Rows>
    <AppHeader State="@ScreenParams.HeaderState" />

    <Panel Title="@ScreenParams.Title" Expand="true">
        <Rows>
            @if (!string.IsNullOrWhiteSpace (ScreenParams.InstructionsMarkup))
            {
                <RawMarkup Content="@ScreenParams.InstructionsMarkup" />
                <Newline />
            }

            <RawMarkup Content="@PromptHintMarkup" />
        </Rows>
    </Panel>

    @if (ScreenParams.TranscriptEntries.Count == 0)
    {
        <Panel Title="Conversation" Expand="true">
            <Rows>
                <RawMarkup Content="@ScreenParams.EmptyStateMarkup" />
            </Rows>
        </Panel>
    }
    else
    {
        @foreach (ConversationTranscriptEntryViewState entry in ScreenParams.TranscriptEntries)
        {
            @if (entry.IsResponse && entry.ResponseState is not null)
            {
                string responsePanelTitle = ResponseMarkupRenderer.BuildPanelTitle (entry.ResponseState);
                string responsePanelContent = ResponseMarkupRenderer.BuildInlineMarkup (entry.ResponseState);

                <Panel Title="@responsePanelTitle" Expand="true">
                    <Rows>
                        <RawMarkup Content="@responsePanelContent" />
                    </Rows>
                </Panel>
            }
            else
            {
                string userBodyMarkup = NormalizeForMarkup (entry.BodyText);

                <Panel Title="@entry.Title" Expand="true">
                    <Rows>
                        <RawMarkup Content="@entry.SpeakerMarkup" />
                        <Newline />
                        <RawMarkup Content="@userBodyMarkup" />
                    </Rows>
                </Panel>
            }
        }
    }

    <StatusBar State="@ScreenParams.StatusBarState" />

    <Newline />
</Rows>

@code {
    private bool _promptLoopStarted;

    private string PromptHintMarkup => "[grey70]Use [bold]Enter[/] to send, [bold]Shift+Enter[/] for a newline, [bold]Up[/]/[bold]Down[/] for history at the top or bottom edge, and [bold]Esc[/] to cancel or exit the current conversation flow.[/]";

    protected override Task OnAfterRenderAsync (bool firstRender)
    {
        if (firstRender && !_promptLoopStarted)
        {
            _promptLoopStarted = true;
            return StartPromptLoopAsync ();
        }

        return Task.CompletedTask;
    }

    private async Task StartPromptLoopAsync ()
    {
        await Task.Yield ();

        if (Console.IsInputRedirected || Console.IsOutputRedirected)
        {
            throw new InvalidOperationException ("Conversation prompt screen requires an interactive console.");
        }

        MultilinePromptEditor promptEditor = new (ScreenParams.HistoryEntries);
        string? prompt = promptEditor.Read (new MultilinePromptEditorOptions
        {
            PromptMarkup = ScreenParams.PromptMarkup,
            PromptText = ScreenParams.PromptText,
            InitialText = ScreenParams.InitialText,
            AllowCancelWithEscape = ScreenParams.AllowCancelWithEscape
        });

        Result.SetResult (new ConversationPromptScreenResult
        {
            Prompt = prompt ?? string.Empty,
            IsCanceled = prompt is null
        });

        AppLifetime.StopApplication ();
    }

    private static string NormalizeForMarkup (string? text)
    {
        return Spectre.Console.Markup.Escape (text ?? string.Empty)
            .Replace ("\r\n", "\n", StringComparison.Ordinal)
            .Replace ('\r', '\n');
    }
}