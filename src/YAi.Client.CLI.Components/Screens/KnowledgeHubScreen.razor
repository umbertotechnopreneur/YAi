@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console
@using YAi.Client.CLI.Components.Components.Dialogs
@using YAi.Persona.Services

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<bool> Result
@inject AppPaths Paths

<Rows>
    <AppHeader />

    <Panel Title="Knowledge Hub">
        <Rows>
            <RawMarkup Content="[grey]Browse and open your persistent memory files.[/]" />
            <Newline />

            @if (_view is HubView.Menu)
            {
                <RawMarkup Content="[bold springgreen2]Select a knowledge store to open:[/]" />
                <Newline />

                <TextButton Content="USER.md" OnClick="SelectUserClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="SOUL.md" OnClick="SelectSoulClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="IDENTITY.md" OnClick="SelectIdentityClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="MEMORIES.md" OnClick="SelectMemoriesClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="LESSONS.md" OnClick="SelectLessonsClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="LIMITS.md" OnClick="SelectLimitsClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="AGENTS.md" OnClick="SelectAgentsClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="Episodes" OnClick="SelectEpisodesClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="Dreams" OnClick="SelectDreamsClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                <TextButton Content="Back" OnClick="BackClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.Silver" />
            }
            else if (_view is HubView.FileActions)
            {
                <Panel Title="@_selectedChoice">
                    <Rows>
                        <RawMarkup Content="@_selectedPathMarkup" />
                        <RawMarkup Content="[grey70]What would you like to do?[/]" />
                        <TextButton Content="Open in editor" OnClick="OpenInEditorClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                        <TextButton Content="View inline" OnClick="ViewInlineClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.SpringGreen2" />
                        <TextButton Content="Back" OnClick="BackToMenuClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.Silver" />
                    </Rows>
                </Panel>
            }
            else if (_view is HubView.Preview)
            {
                <RawMarkup Content="@_previewHeaderMarkup" />
                <RawMarkup Content="@_previewPathMarkup" />
                <Newline />
                <Panel Title="Preview">
                    <RawMarkup Content="@_previewContentMarkup" />
                </Panel>

                if (!string.IsNullOrWhiteSpace(_previewFooterMarkup))
                {
                    <RawMarkup Content="@_previewFooterMarkup" />
                }

                <Newline />
                <TextButton Content="Back" OnClick="BackToMenuClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.Silver" />
            }
            else if (_view is HubView.Notice)
            {
                <MessageBox Severity="@_noticeSeverity"
                            Message="@_noticeMessage"
                            OnDismiss="BackToMenuClicked" />
            }
        </Rows>
    </Panel>
</Rows>

@code {
    private enum HubView
    {
        Menu,
        FileActions,
        Preview,
        Notice
    }

    private HubView _view = HubView.Menu;
    private string _selectedChoice = string.Empty;
    private string _selectedPath = string.Empty;
    private string _selectedPathMarkup = string.Empty;
    private string _previewHeaderMarkup = string.Empty;
    private string _previewPathMarkup = string.Empty;
    private string _previewContentMarkup = string.Empty;
    private string _previewFooterMarkup = string.Empty;
    private string _noticeMessage = string.Empty;
    private MessageBox.MessageSeverity _noticeSeverity = MessageBox.MessageSeverity.Info;

    protected override void OnInitialized ()
    {
        Console.Clear ();
        AnsiConsole.Clear ();
        Console.Write ("\x1b[3J");
    }

    private Task SelectUserClicked () => SelectChoiceAsync ("USER.md");

    private Task SelectSoulClicked () => SelectChoiceAsync ("SOUL.md");

    private Task SelectIdentityClicked () => SelectChoiceAsync ("IDENTITY.md");

    private Task SelectMemoriesClicked () => SelectChoiceAsync ("MEMORIES.md");

    private Task SelectLessonsClicked () => SelectChoiceAsync ("LESSONS.md");

    private Task SelectLimitsClicked () => SelectChoiceAsync ("LIMITS.md");

    private Task SelectAgentsClicked () => SelectChoiceAsync ("AGENTS.md");

    private Task SelectEpisodesClicked () => SelectChoiceAsync ("Episodes");

    private Task SelectDreamsClicked () => SelectChoiceAsync ("Dreams");

    private Task SelectChoiceAsync (string choice)
    {
        if (string.Equals (choice, "Back", StringComparison.OrdinalIgnoreCase))
        {
            return BackClicked ();
        }

        if (string.Equals (choice, "Episodes", StringComparison.OrdinalIgnoreCase))
        {
            if (!KnowledgeHubScreenHelper.DirectoryExists(Paths.EpisodesRoot))
            {
                ShowNotice ($"Episodes directory not found: {Paths.EpisodesRoot}", MessageBox.MessageSeverity.Warning);
                return Task.CompletedTask;
            }

            if (!KnowledgeHubScreenHelper.TryOpenInEditor(Paths.EpisodesRoot, out string? errorMessage))
            {
                ShowNotice (errorMessage ?? "Could not open the episodes directory.", MessageBox.MessageSeverity.Error);
                return Task.CompletedTask;
            }

            return BackToMenuClicked ();
        }

        string filePath = KnowledgeHubScreenHelper.ResolveFilePath(Paths, choice);

        if (string.IsNullOrWhiteSpace(filePath) || !KnowledgeHubScreenHelper.FileExists(filePath))
        {
            ShowNotice ($"File not found: {filePath}", MessageBox.MessageSeverity.Warning);
            return Task.CompletedTask;
        }

        _selectedChoice = choice;
        _selectedPath = filePath;
        _selectedPathMarkup = $"[grey]{Spectre.Console.Markup.Escape (filePath)}[/]";
        _view = HubView.FileActions;

        return Task.CompletedTask;
    }

    private Task OpenInEditorClicked ()
    {
        if (string.IsNullOrWhiteSpace (_selectedPath))
        {
            return BackToMenuClicked ();
        }

        if (!KnowledgeHubScreenHelper.TryOpenInEditor(_selectedPath, out string? errorMessage))
        {
            ShowNotice (errorMessage ?? "Could not open the selected file.", MessageBox.MessageSeverity.Error);
            return Task.CompletedTask;
        }

        return BackToMenuClicked ();
    }

    private Task ViewInlineClicked ()
    {
        if (string.IsNullOrWhiteSpace(_selectedPath) || !KnowledgeHubScreenHelper.FileExists(_selectedPath))
        {
            ShowNotice ($"File not found: {_selectedPath}", MessageBox.MessageSeverity.Warning);
            return Task.CompletedTask;
        }

        (
            _previewHeaderMarkup,
            _previewPathMarkup,
            _previewContentMarkup,
            _previewFooterMarkup) = KnowledgeHubScreenHelper.BuildInlinePreview(_selectedChoice, _selectedPath);
        _view = HubView.Preview;

        return Task.CompletedTask;
    }

    private Task BackToMenuClicked ()
    {
        _view = HubView.Menu;
        _selectedChoice = string.Empty;
        _selectedPath = string.Empty;
        _selectedPathMarkup = string.Empty;
        _previewHeaderMarkup = string.Empty;
        _previewPathMarkup = string.Empty;
        _previewContentMarkup = string.Empty;
        _previewFooterMarkup = string.Empty;

        return Task.CompletedTask;
    }

    private Task BackClicked ()
    {
        Result.SetResult (true);
        AppLifetime.StopApplication ();

        return Task.CompletedTask;
    }

    private void ShowNotice (string message, MessageBox.MessageSeverity severity)
    {
        _noticeMessage = message;
        _noticeSeverity = severity;
        _view = HubView.Notice;
    }

}