@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<bool> Result

<Rows>
    <Newline />

    <Panel Title="Launch sequence">
        <Rows>
            <RawMarkup Content="@BannerArt" Foreground="@Color.Cyan1" />
            <Newline />
            <RawMarkup Content="[dim]workspace intelligence for the current session[/]" />
            <RawMarkup Content="[dim]orchestrate · inspect · reset · repeat[/]" />
            <Newline />
            <RawMarkup Content="[dim]Copyright © 2019-2026 UmbertoGiacobbiDotBiz. All rights reserved.[/]" />
            <RawMarkup Content="Website: [link=https://umbertogiacobbi.biz][underline]umbertogiacobbi.biz[/][/]"
                       Foreground="@Color.DeepSkyBlue1" />
            <RawMarkup
            Content="Email: [link=mailto:hello@umbertogiacobbi.biz][underline]hello@umbertogiacobbi.biz[/][/]"
            Foreground="@Color.SpringGreen2" />
        </Rows>
    </Panel>

    <Newline />
</Rows>

@code {
    private const string BannerArt = """
    ╭────────────────────────────╮
    │   [bold cyan1]YAi![/]   [grey70]signal online[/]   │
    │ [grey70]workspace intelligence[/] │
    ╰────────────────────────────╯
    """;

    protected override Task OnAfterRenderAsync (bool firstRender)
    {
        if (!firstRender)
        {
            return Task.CompletedTask;
        }

        Result.SetResult (true);
        AppLifetime.StopApplication ();

        return Task.CompletedTask;
    }
}