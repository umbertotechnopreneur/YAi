@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using RazorConsole.Components
@using Spectre.Console

<Rows>
    <Panel Title="@Title">
        <Rows>
            <RawMarkup Content="@Spectre.Console.Markup.Escape(Message)" Foreground="@_riskColor" />
            <Newline />
            <Columns>
                <TextButton Content="[Y] Yes"
                            OnClick="ConfirmClicked"
                            BackgroundColor="@Color.Green"
                            FocusedColor="@Color.Green3" />
                <TextButton Content="[Esc] Cancel"                           OnClick="CancelClicked"
                            BackgroundColor="@Color.Grey"
                            FocusedColor="@Color.Silver" />
            </Columns>
        </Rows>
    </Panel>
</Rows>

@code {
    /// <summary>Dialog title.</summary>
    [Parameter] public string Title { get; set; } = "Confirm";

    /// <summary>Confirmation message body.</summary>
    [Parameter] public string Message { get; set; } = "Are you sure?";

    /// <summary>Optional risk color override for the message text.</summary>
    [Parameter] public Color RiskColor { get; set; } = Color.White;

    /// <summary>Raised when the user chooses Yes.</summary>
    [Parameter] public EventCallback OnConfirm { get; set; }

    /// <summary>Raised when the user chooses No.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    private Color _riskColor;

    protected override void OnParametersSet ()
    {
        _riskColor = RiskColor;
    }

    private async Task ConfirmClicked () => await OnConfirm.InvokeAsync ();
    private async Task CancelClicked () => await OnCancel.InvokeAsync ();
}
