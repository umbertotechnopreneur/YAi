@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using YAi.Client.CLI.Components.Components.Cards
@using YAi.Client.CLI.Components.Screens
@using YAi.Persona.Services.Operations.Models
@using YAi.Persona.Services.Tools.Filesystem.Models

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<ApprovalDecision> Result
@inject ApprovalCardScreenParams ScreenParams
@inject FilesystemOperationStep Card

<ApprovalCard Card="@Card"
              RemainingCount="@ScreenParams.RemainingCount"
              OnDecision="DecisionMade" />

@code {
    private void DecisionMade (ApprovalDecision decision)
    {
        Result.SetResult (decision);
        AppLifetime.StopApplication ();
    }
}
