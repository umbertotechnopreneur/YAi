@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console
@using YAi.Client.CLI.Components.Components.Dialogs
@using YAi.Persona.Models
@using YAi.Persona.Services

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<bool> Result
@inject PromotionService Promotion

<Rows>
    <AppHeader />

    <Panel Title="Review Dreams">
        <Rows>
            <RawMarkup Content="[grey]Promote or reject proposals generated by the dreaming reflection pass.[/]" />
            <Newline />

            @if (_view is DreamsView.Loading)
            {
                <RawMarkup Content="[cyan]Loading pending proposals...[/]" />
            }
            else if (_view is DreamsView.Empty)
            {
                <RawMarkup Content="[grey]No pending proposals found in candidates.jsonl.[/]" />
                <RawMarkup Content="[grey]Run [bold]--dream[/] first to generate new proposals.[/]" />
                <Newline />
                <TextButton Content="[Enter] Back" OnClick="BackClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.Silver" />
            }
            else if (_view is DreamsView.List)
            {
                <RawMarkup Content="[bold magenta]Pending proposals[/]" />
                <Newline />

                @for (int i = 0; i < _proposals.Count; i++)
                {
                    ProposalCardViewModel card = _proposalCards[i];
                    int proposalIndex = i;

                    <RawMarkup Content="@card.SummaryMarkup" />
                    <TextButton Content="@($"Review {card.Number}")"
                                OnClick="@(() => OpenProposal (proposalIndex))"
                                BackgroundColor="@Color.Grey"
                                FocusedColor="@Color.SpringGreen2" />
                }

                <Newline />
                <TextButton Content="Back" OnClick="BackClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.Silver" />
            }
            else if (_view is DreamsView.Detail && _selectedProposal is not null)
            {
                <Panel Title="Dream Proposal">
                    <Rows>
                        <RawMarkup Content="@_detailTypeMarkup" />
                        <RawMarkup Content="@_detailContentMarkup" />
                        <RawMarkup Content="@_detailRationaleMarkup" />
                        <RawMarkup Content="@_detailConfidenceMarkup" />
                        <Newline />
                        <TextButton Content="[A] Approve"
                                    OnClick="ApproveClicked"
                                    BackgroundColor="@Color.Green"
                                    FocusedColor="@Color.Green3" />
                        <TextButton Content="[R] Reject"
                                    OnClick="RejectClicked"
                                    BackgroundColor="@Color.DarkRed"
                                    FocusedColor="@Color.OrangeRed1" />
                        <TextButton Content="Back" OnClick="BackToListClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.Silver" />
                    </Rows>
                </Panel>
            }
            else if (_view is DreamsView.Notice)
            {
                <MessageBox Severity="@_noticeSeverity"
                            Message="@_noticeMessage"
                            OnDismiss="DismissNotice" />
            }
            else if (_view is DreamsView.Complete)
            {
                <RawMarkup Content="[grey]All proposals reviewed.[/]" />
                <Newline />
                <TextButton Content="[Enter] Return" OnClick="BackClicked" BackgroundColor="@Color.Grey" FocusedColor="@Color.Silver" />
            }
        </Rows>
    </Panel>
</Rows>

@code {
    private enum DreamsView
    {
        Loading,
        List,
        Detail,
        Notice,
        Empty,
        Complete
    }

    private sealed record ProposalCardViewModel (int Number, string SummaryMarkup);

    private readonly List<ExtractionCandidate> _proposals = [];
    private readonly List<ProposalCardViewModel> _proposalCards = [];

    private DreamsView _view = DreamsView.Loading;
    private int _selectedIndex;
    private ExtractionCandidate? _selectedProposal;
    private string _detailTypeMarkup = string.Empty;
    private string _detailContentMarkup = string.Empty;
    private string _detailRationaleMarkup = string.Empty;
    private string _detailConfidenceMarkup = string.Empty;
    private string _noticeMessage = string.Empty;
    private MessageBox.MessageSeverity _noticeSeverity = MessageBox.MessageSeverity.Info;

    protected override void OnInitialized ()
    {
        Console.Clear ();
        AnsiConsole.Clear ();
        Console.Write ("\x1b[3J");
    }

    protected override async Task OnInitializedAsync ()
    {
        await RefreshProposalsAsync ().ConfigureAwait (false);
    }

    private async Task RefreshProposalsAsync ()
    {
        _view = DreamsView.Loading;
        await InvokeAsync (StateHasChanged).ConfigureAwait (false);

        _proposals.Clear ();
        _proposals.AddRange (await Promotion.GetPendingProposalsAsync ().ConfigureAwait (false));

        RebuildProposalCards ();

        _view = _proposals.Count == 0
            ? DreamsView.Empty
            : DreamsView.List;
    }

    private void RebuildProposalCards ()
    {
        _proposalCards.Clear ();

        for (int i = 0; i < _proposals.Count; i++)
        {
            ExtractionCandidate proposal = _proposals[i];
            string preview = proposal.Content.Length > 60
                ? proposal.Content[..60] + "…"
                : proposal.Content;

            _proposalCards.Add (
                new ProposalCardViewModel (
                    i + 1,
                    $"[dim]{i + 1}.[/] [dim]{Spectre.Console.Markup.Escape (proposal.EventType)}[/] {Spectre.Console.Markup.Escape (preview)} [grey70]({proposal.Confidence:P0})[/]"));
        }
    }

    private Task OpenProposal (int index)
    {
        if (index < 0 || index >= _proposals.Count)
        {
            return Task.CompletedTask;
        }

        _selectedIndex = index;
        _selectedProposal = _proposals[index];

        string rationale = _selectedProposal.Metadata.GetValueOrDefault ("rationale", string.Empty);
        _detailTypeMarkup = $"[bold]Type:[/] {Spectre.Console.Markup.Escape (_selectedProposal.EventType)}";
        _detailContentMarkup = $"[bold]Content:[/] {Spectre.Console.Markup.Escape (_selectedProposal.Content)}";
        _detailRationaleMarkup = $"[bold]Rationale:[/] {Spectre.Console.Markup.Escape (rationale)}";
        _detailConfidenceMarkup = $"[bold]Confidence:[/] {_selectedProposal.Confidence:P0}";
        _view = DreamsView.Detail;

        return Task.CompletedTask;
    }

    private async Task ApproveClicked ()
    {
        if (_selectedProposal is null)
        {
            return;
        }

        PromotionResult result = await Promotion.PromoteAsync (_selectedProposal).ConfigureAwait (false);

        _noticeSeverity = result.Success
            ? MessageBox.MessageSeverity.Info
            : MessageBox.MessageSeverity.Warning;

        _noticeMessage = result.Success
            ? $"Promoted: {Spectre.Console.Markup.Escape (_selectedProposal.Content)}"
            : $"Blocked: {Spectre.Console.Markup.Escape (result.BlockedReason ?? "Unknown reason")}";

        _view = DreamsView.Notice;
    }

    private async Task RejectClicked ()
    {
        if (_selectedProposal is null)
        {
            return;
        }

        await Promotion.RejectAsync (_selectedProposal).ConfigureAwait (false);

        _noticeSeverity = MessageBox.MessageSeverity.Info;
        _noticeMessage = $"Rejected: {Spectre.Console.Markup.Escape (_selectedProposal.Content)}";
        _view = DreamsView.Notice;
    }

    private async Task DismissNotice ()
    {
        await RefreshProposalsAsync ().ConfigureAwait (false);

        if (_proposals.Count == 0)
        {
            _view = DreamsView.Complete;
        }
        else
        {
            _view = DreamsView.List;
            _selectedProposal = null;
        }
    }

    private Task BackToListClicked()
    {
        _selectedProposal = null;
        _view = DreamsView.List;

        return Task.CompletedTask;
    }

    private Task BackClicked ()
    {
        Result.SetResult (true);
        AppLifetime.StopApplication ();

        return Task.CompletedTask;
    }
}