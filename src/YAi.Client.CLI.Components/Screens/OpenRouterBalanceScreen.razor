@using System.Globalization
@using Microsoft.AspNetCore.Components
@using Microsoft.Extensions.Hosting
@using RazorConsole.Components
@using Spectre.Console
@using YAi.Persona.Models

@inject IHostApplicationLifetime AppLifetime
@inject RazorScreenResult<bool> Result
@inject OpenRouterBalanceSnapshot Snapshot

<Rows>
    <Panel Title="OpenRouter balance">
        <Rows>
            <RawMarkup Content="This screen is cached for 10 minutes to avoid unnecessary credits API calls."
                       Foreground="@Color.Silver" />
            <Newline />

            <Columns>
                <Panel Title="Remaining">
                    <Rows>
                        <RawMarkup Content="@GetRemainingSummaryMarkup()" />
                    </Rows>
                </Panel>

                <Panel Title="Spent">
                    <Rows>
                        <RawMarkup Content="@GetSpentSummaryMarkup()" />
                    </Rows>
                </Panel>

                <Panel Title="Source">
                    <Rows>
                        <RawMarkup Content="@GetSourceSummaryMarkup()" />
                    </Rows>
                </Panel>
            </Columns>

            <Newline />

            <Panel Title="Details">
                <Rows>
                    <Columns>
                        <RawMarkup Content="Total credits:" />
                        <RawMarkup Content="@Spectre.Console.Markup.Escape(_totalCredits)" />
                    </Columns>

                    @if (!string.IsNullOrWhiteSpace(Snapshot.ErrorMessage))
                    {
                        <Newline />
                        <RawMarkup Content="@Spectre.Console.Markup.Escape(Snapshot.ErrorMessage)"
                                   Foreground="@Color.Yellow" />
                    }
                </Rows>
            </Panel>
        </Rows>
    </Panel>
</Rows>

@code {
    private string _remainingBalance = string.Empty;
    private string _totalSpent = string.Empty;
    private string _totalCredits = string.Empty;
    private string _lastBalanceCheck = string.Empty;
    private string _sourceLabel = string.Empty;

    protected override void OnInitialized ()
    {
        _remainingBalance = FormatMoney (Snapshot.RemainingCredits);
        _totalSpent = FormatMoney (Snapshot.TotalUsage);
        _totalCredits = FormatMoney (Snapshot.TotalCredits);
        _lastBalanceCheck = Snapshot.LastBalanceCheckUtc.ToString ("u", CultureInfo.InvariantCulture);
        _sourceLabel = Snapshot.IsFromCache ? "cache" : "live";
    }

    protected override Task OnAfterRenderAsync (bool firstRender)
    {
        if (firstRender)
        {
            Result.SetResult (true);
            AppLifetime.StopApplication ();
        }

        return Task.CompletedTask;
    }

    private static string FormatMoney (decimal? amount)
    {
        return amount.HasValue
            ? $"${amount.Value:0.######}"
            : "n/a";
    }

    private string GetRemainingSummaryMarkup()
    {
        if (!Snapshot.HasBalance)
        {
            return "[bold red]unavailable[/]\n[grey70]balance not parsed[/]";
        }

        return $"[bold green]{_remainingBalance}[/]\n[grey70]remaining credits[/]";
    }

    private string GetSpentSummaryMarkup()
    {
        if (!Snapshot.HasBalance)
        {
            return "[bold red]unavailable[/]\n[grey70]usage not parsed[/]";
        }

        return $"[bold yellow]{_totalSpent}[/]\n[grey70]usage to date[/]";
    }

    private string GetSourceSummaryMarkup()
    {
        string sourceMarkup = Snapshot.IsFromCache
            ? "[bold cyan1]cache[/]"
            : "[bold springgreen2]live[/]";

        return $"{sourceMarkup}\n[grey70]{Spectre.Console.Markup.Escape(_lastBalanceCheck)}[/]";
    }
}