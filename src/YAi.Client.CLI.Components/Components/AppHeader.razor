@namespace YAi.Client.CLI.Components

@using Microsoft.AspNetCore.Components
@using RazorConsole.Components
@using YAi.Client.CLI.Components.Rendering

<Panel Expand="true">
    <RawMarkup Content="@AppHeaderMarkupRenderer.BuildMarkup(HeaderState)" />
</Panel>

@code {
    /// <summary>
    /// Gets or sets the application header state to render.
    /// </summary>
    [Parameter]
    public AppHeaderState? State { get; set; }

    private AppHeaderState HeaderState => State ?? AppHeaderState.Current;
}