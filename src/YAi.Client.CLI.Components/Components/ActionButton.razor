    YAi.Client.CLI.Components
    ActionButton — standard wrapper around TextButton for primary, danger, and neutral button variants
*@

@namespace RazorConsole.Components

@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Spectre.Console

<TextButton Content="@Content"
            OnClick="@OnClick"
            BackgroundColor="@ResolvedBackgroundColor"
            FocusedColor="@ResolvedFocusedColor" />

@code {
    /// <summary>Button label or markup text.</summary>
    [Parameter, EditorRequired]
    public string Content { get; set; } = string.Empty;

    /// <summary>Raised when the button is activated.</summary>
    [Parameter]
    public EventCallback OnClick { get; set; }

    /// <summary>Semantic tone used to resolve the default button palette.</summary>
    [Parameter]
    public string Tone { get; set; } = "neutral";

    /// <summary>Optional explicit background color override.</summary>
    [Parameter]
    public Color? BackgroundColor { get; set; }

    /// <summary>Optional explicit focused-state color override.</summary>
    [Parameter]
    public Color? FocusedColor { get; set; }

    private string NormalizedTone => string.IsNullOrWhiteSpace (Tone)
        ? "neutral"
        : Tone.Trim ().ToLowerInvariant ();

    private Color ResolvedBackgroundColor => BackgroundColor ?? NormalizedTone switch
    {
        "primary" => Color.Green,
        "danger"  => Color.Orange1,
        _          => Color.Grey
    };

    private Color ResolvedFocusedColor => FocusedColor ?? NormalizedTone switch
    {
        "primary" => Color.Green3,
        "danger"  => Color.Gold1,
        _          => Color.Silver
    };
}